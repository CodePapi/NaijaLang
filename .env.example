# environment variables for local development
# never commit a real token. add the real value to your own .env file

# when publishing the nigeria-languages npm package this repo uses
# GitHub Actions; set the `NPM_TOKEN` secret in your repository settings.
#
# Note: if your npm account has two-factor authentication enabled,
# create an "Automation" token that has permission to bypass 2FA
# (see https://www.npmjs.com/settings/<your-username>/tokens). Store
# that token here or in the repository secret. Ordinary 2FA codes
# cannot be provided by Actions.

NPM_TOKEN=your_npm_token_here
