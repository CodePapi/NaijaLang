# Example environment variables for ai-model
DATABASE_URL="postgresql://prisma:prisma@localhost:5432/ai_model"
PRISMA_CLIENT_ENGINE_TYPE=binary   # use binary engine to avoid adapter requirement
PORT=3000

# when using a cloud LLM like OpenAI for embeddings/translation,
# set the API key here (leave blank to use the built-in hashing embedder)
OPENAI_API_KEY=
